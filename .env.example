# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# Database (local dev uses Docker Compose defaults)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gym_coach

# Redis (local dev uses Docker Compose defaults)
REDIS_URL=redis://localhost:6379/0

# Auth — change JWT_SECRET before any real deployment
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# LLM / AI — get real keys from console.anthropic.com and dash.voyageai.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
VOYAGE_API_KEY=your-voyage-api-key-here
SONNET_MODEL_ID=claude-sonnet-4-6
HAIKU_MODEL_ID=claude-haiku-4-5-20251001
EMBED_MODEL_ID=voyage-4-lite

# CORS / cookies
CORS_ORIGINS=["http://localhost:5173"]
COOKIE_SAMESITE=lax
COOKIE_SECURE=False
